# Copy this file to .env.local and fill in your values
# Get these from Firebase Console > Project Settings > Your apps > Web app

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# URL of your deployed Firebase Function (or emulator for local dev)
# Local:  http://127.0.0.1:5001/YOUR_PROJECT_ID/us-central1
# Prod:   https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net
VITE_FUNCTIONS_URL=http://127.0.0.1:5001/your_project_id/us-central1
